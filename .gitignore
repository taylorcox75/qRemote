# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/
key.json
# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
*.orig.*
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# editor swap files
*.swp
*.swo

# local env files
.env*.local

# typescript
*.tsbuildinfo

# test coverage
coverage/

# ios/ is committed as source of truth (bare React Native workflow) -- it is
# no longer regenerated by `expo prebuild`. Pods/, build/, xcuserdata, and
# other machine-local/derived paths are excluded by ios/.gitignore.

.audit/
