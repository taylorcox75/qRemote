# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/
key.json
# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# test coverage
coverage/

# generated native folders
/android

# /ios is generated (Expo continuous native generation), but Xcode Cloud
# validates the project/scheme against what's pushed to the repo before it
# will let you create a workflow ("scheme may only exist locally" error) --
# so the actual project + scheme need to be committed too, alongside the
# ci_scripts hook that keeps them fresh on every Xcode Cloud run via
# `npm run pre`. Pods/ and build/ stay regenerated (see ios/.gitignore).
/ios/*
!/ios/ci_scripts
!/ios/qRemote.xcodeproj
!/ios/qRemote.xcworkspace
!/ios/qRemote
!/ios/Podfile
!/ios/Podfile.lock
!/ios/Podfile.properties.json
!/ios/.xcode.env
!/ios/.gitignore
