# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/
key.json
# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# test coverage
coverage/

# generated native folders
/android

# /ios is generated (Expo continuous native generation) but Xcode Cloud's
# ci_scripts hook must be committed for Apple's build service to see it
# (the hook itself regenerates the rest of /ios via `npm run pre`)
/ios/*
!/ios/ci_scripts
